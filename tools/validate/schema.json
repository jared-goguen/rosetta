{
  "input": {
    "type": "object",
    "properties": {
      "type": {
        "type": "string",
        "enum": ["tool", "command", "plugin"],
        "description": "Type of artifact to validate"
      },
      "name": {
        "type": "string",
        "description": "Name of the artifact to validate"
      }
    },
    "required": ["type", "name"],
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "properties": {
      "valid": {
        "type": "boolean",
        "description": "Whether the artifact passes validation"
      },
      "errors": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of validation errors if any"
      }
    },
    "required": ["valid", "errors"]
  }
}