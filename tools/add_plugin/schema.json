{
  "input": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Name of the plugin to create"
      },
      "content": {
        "type": "string", 
        "description": "TypeScript source code for index.ts"
      },
      "manifest": {
        "type": "object",
        "properties": {
          "version": { "type": "string" },
          "description": { "type": "string" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["version"]
      },
      "files": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Additional files to create under src/"
      }
    },
    "required": ["name", "content", "manifest"],
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "properties": {
      "path": { "type": "string" }
    },
    "required": ["path"]
  }
}
