{
  "input": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Name of the tool to create (becomes directory name)"
      },
      "content": {
        "type": "string",
        "description": "TypeScript source code for index.ts"
      },
      "description": {
        "type": "string",
        "description": "Human-readable description written to purpose.md"
      },
      "schema": {
        "type": "object",
        "properties": {
          "input": {
            "type": "object",
            "description": "JSON Schema for tool inputs"
          },
          "output": {
            "type": "object",
            "description": "JSON Schema for tool outputs"
          }
        },
        "required": ["input", "output"],
        "additionalProperties": false
      }
    },
    "required": ["name", "content"],
    "additionalProperties": false
  },
  "output": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "Full path to the created tool directory"
      }
    },
    "required": ["path"]
  }
}